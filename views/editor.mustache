<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <title>Editor</title>
    <script src="https://cdn.tiny.cloud/1/{{apiKey}}/tinymce/7/tinymce.min.js" referrerpolicy="origin"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
</head>

<body>
    <div class="container mt-3 mb-3">
        <h1 class="h3 mb-4">Welcome {{fullname}} <a class="btn btn-link" href="/logout">Logout</a></h1>
        <p>TinyMCE editor instance setup with Image Optimizer integrated with Signed Uploads.</p>
        <textarea>
            <p>To see the signed upload request, open the browser Network tab to see the signed upload request, then make an
                operation on the image below.</p>
            <p><img src="https://google.com/logos/google.jpg" width="354" height="116" /></p>
        </textarea>
    </div>

    <script type="text/javascript">
        tinymce.init({
            selector: "textarea",
            plugins: "uploadcare link media code",
            toolbar: "uploadcare link media | code | undo redo",
            // Image Optimizer specific options - for more details, refer to https://www.tiny.cloud/docs/tinymce/latest/uploadcare/
            uploadcare_public_key: "{{uploadcarePublicKey}}",
            uploadcare_store_type: "temporary",
            uploadcare_srcset_steps: [100, 200, 300, 500, 750],
            a11y_advanced_options: true,
            uploadcare_signed_upload_auth_provider: async (publicKey) => {
                try {
                    const response = await fetch("/signature", {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/json",
                        },
                        body: JSON.stringify({ publicKey }),
                    });
                    if (!response.ok) {
                        throw new Error(
                            "Service returned an error: " + response.statusText
                        );
                    }
                    const data = await response.json();
                    return {
                        signature: data.signature,
                        expire: data.expire,
                    };
                } catch (error) {
                    console.error(error);
                }
            },
        });
    </script>
</body>

</html>