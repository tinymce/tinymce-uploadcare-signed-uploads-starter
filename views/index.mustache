<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <title>Login</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
</head>

<body>
    <div class="container vh-100 d-flex justify-content-center align-items-center">
        <form method="post" action="/">
            {{#error}}
            <div class="alert alert-danger" role="alert">{{error}}</div>
            {{/error}}

            <h1 class="h3 mb-3">Login</h1>
            <p>Login with the user/passwords available in the <code>config.js</code> file</p>

            <div class="form-group">
                <label for="username" class="font-weight-bold">User</label>
                <input type="text" class="form-control" id="username" name="username" value="johndoe">
            </div>

            <div class="form-group">
                <label for="password" class="font-weight-bold">Password</label>
                <input type="password" class="form-control" id="password" name="password" value="password">
            </div>

            <div class="form-group">
                <input type="submit" class="btn btn-primary" value="Login">
            </div>
        </form>
    </div>
</body>

</html>